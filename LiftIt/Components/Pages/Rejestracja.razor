@page "/rejestracja"
@layout MainLayout
@implements IRejestracjaView

<div class="auth-container">
    <div class="auth-card">

        <h3>Welcome to LiftIt!</h3>
        <p class="subtitle">Fill all the fields to sign up.</p>

        <form @onsubmit="OnRejestracjaClicked">

            <div class="input-group">
                <label for="login">Login</label>
                <input id="login" class="form-control" placeholder="Login" @bind="Login" required />
            </div>

            <div class="input-group">
                <label for="email">E-mail</label>
                <input id="email" type="email" class="form-control" placeholder="example@email.com" @bind="Email" required />
            </div>

            <div class="input-group">
                <label for="password">Password</label>
                <input id="password" type="password" class="form-control" placeholder="••••••••" @bind="Password" required />
            </div>

            <div class="input-group">
                <label for="password-confirm">Confirm password</label>
                <input id="password-confirm" type="password" class="form-control" placeholder="••••••••" @bind="PasswordConfirm" required />
            </div>

            <button type="submit" class="btn-primary-custom">Sign Up</button>
        </form>

        <div class="register-redirect">
            <span>Already have an account? <a href="/logowanie">Sign in</a></span>
        </div>

    </div>
</div>

@code {
    [Inject] public Models.DatabaseContext DbContext { get; set; } // Wstrzykujemy model bazy danych

    private RejestracjaPresenter _presenter;

    public event Action SignUpUser;
    public string Login { get; set; }
    public string Email { get; set; }
    public string Password { get; set; }
    public string PasswordConfirm { get; set; }

    protected override void OnInitialized()
    {
        // Tworzymy prezenter i przekazujemy mu ten Widok (this) oraz Model (DbContext)
        _presenter = new RejestracjaPresenter(this, DbContext);
    }

    private void OnRejestracjaClicked()
    {
        SignUpUser?.Invoke();
    }
}
