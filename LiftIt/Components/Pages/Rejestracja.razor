@page "/rejestracja"
@layout MainLayout
@implements IRejestracjaView

<div class="auth-container">
    <div class="auth-card">

        <h3>Witaj w LiftIt!</h3>
        <p class="subtitle">Sign Up</p>

        <form @onsubmit="OnRejestracjaClicked">

            <div class="input-group">
                <label for="fullname">Fullname</label>
                <input id="fullname" class="form-control" placeholder="Fullname" @bind="Fullname" required />
            </div>

            <div class="input-group">
                <label for="email">E-mail</label>
                <input id="email" type="email" class="form-control" placeholder="example@email.com" @bind="Email" required />
            </div>

            <div class="input-group">
                <label for="password">Password</label>
                <input id="password" type="password" class="form-control" placeholder="••••••••" @bind="Password" required />
            </div>

            <div class="input-group">
                <label for="password-confirm">Confirm password</label>
                <input id="password-confirm" type="password" class="form-control" placeholder="••••••••" @bind="PasswordConfirm" required />
            </div>

            <button type="submit" class="btn-primary-custom">SIGN UP</button>
        </form>

        <div class="register-redirect">
            <span>Already have an account? <a href="/logowanie">Log in</a></span>
        </div>

    </div>
</div>

@code {
    // Tutaj w przyszłości dodasz bindowanie pól i wywołanie Prezentera
    public string Fullname { get; set; }
    public string Email { get; set; }
    public string Password { get; set; }
    public string PasswordConfirm { get; set; }

    private void OnRejestracjaClicked()
    {
        // Tutaj wywołanie: _presenter.Zaloguj();
    }
}
