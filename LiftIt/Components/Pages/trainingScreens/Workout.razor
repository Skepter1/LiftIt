@page "/workout"
@page "/workout/{PlanId:int}"
@layout MainLayout
@implements LiftIt.Interfaces.IWorkoutView
@inject LiftIt.Models.DatabaseContext DbContext
@inject LiftIt.Models.StateService StateService

<div class="tab-with-topbar-container">
    <div class="w-100 d-flex justify-content-between align-items-center header-container px-3 py-2">
        <NavLink href="trening" class="d-flex align-items-center text-decoration-none">
            <span class="bi bi-left-arrow accent-text"></span>
        </NavLink>
        <h3 class="m-0 page-title">Live Workout</h3>
        <div style="width: 2rem;"></div>
    </div>

    <div class="p-3">
        @if (CurrentTrainingId == 0)
        {
            <div class="text-center mt-5">
                <button class="btn-primary-custom w-100 mt-4" @onclick="() => StartSessionRequested?.Invoke()">
                    @(PlanId > 0 ? "Rozpocznij Wybrany Plan" : "Start Pustej Sesji")
                </button>
            </div>
        }
        else
        {
            <div class="mb-4">
                <span class="badge bg-success">Sesja Aktywna</span>
                <small class="text-muted ms-2">ID: @CurrentTrainingId</small>
            </div>

            @if (PlanLoadedItems != null && PlanLoadedItems.Count > 0)
            {
                <h5 style="color: var(--text-main);">Ćwiczenia z planu</h5>
                @foreach (var item in PlanLoadedItems)
                {
                    <div class="card mb-3 p-3" style="background-color: var(--card-bg); border: none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong style="color: var(--text-main); font-size: 1.1rem;">@item.ExerciseName</strong>
                                <div class="text-muted small">@item.BodyPartName</div>
                            </div>
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => ToggleExerciseSets(item.ExerciseId)">
                                @(visibleExerciseSets.Contains(item.ExerciseId) ? "Zwiń" : "Pokaż Serie")
                            </button>
                        </div>

                        @if (visibleExerciseSets.Contains(item.ExerciseId))
                        {
                            <div class="mt-3 pt-3" style="border-top: 1px solid var(--input-border);">
                                <div class="d-flex gap-2 align-items-end">
                                    <div class="flex-grow-1">
                                        <label class="small text-muted">Seria</label>
                                        <input class="form-control text-center p-2" type="number" @bind="perExerciseSetNumber[item.ExerciseId]" min="1" />
                                    </div>
                                    <div class="flex-grow-1">
                                        <label class="small text-muted">kg</label>
                                        <input class="form-control text-center p-2" type="number" step="0.25" @bind="perExerciseWeight[item.ExerciseId]" />
                                    </div>
                                    <div class="flex-grow-1">
                                        <label class="small text-muted">Reps</label>
                                        <input class="form-control text-center p-2" type="number" @bind="perExerciseReps[item.ExerciseId]" />
                                    </div>
                                    <button class="btn btn-success p-2 mb-0" style="height: 42px;" @onclick="() => TriggerAddSet(item.ExerciseId)">Dodaj</button>
                                </div>

                                <div class="mt-3">
                                    @if (ExerciseSets.TryGetValue(item.ExerciseId, out var list) && list.Count > 0)
                                    {
                                        <ul class="list-group list-group-flush" style="background: transparent;">
                                            @foreach (var s in list)
                                            {
                                                <li class="list-group-item d-flex justify-content-between" style="background: transparent; color: var(--text-main); border-color: var(--input-border); padding: 5px 0;">
                                                    <span>Seria @s.SetNumber</span>
                                                    <strong>@s.Weight kg x @s.Reps</strong>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="text-muted small mt-2 m-0">Brak serii.</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center p-4 mb-4" style="border: 1px dashed var(--input-border); border-radius: 8px;">
                    <p class="text-muted m-0">Brak załadowanych ćwiczeń z planu. Możesz dodać ćwiczenia ręcznie lub uruchomić plan z zakładki Rutyny.</p>
                </div>
            }

            <div class="mt-4 p-3" style="background-color: var(--options-bg); border-radius: 12px;">
                <label class="text-muted mb-2">Notatka końcowa</label>
                <textarea class="form-control mb-3" @bind="EndNotes"></textarea>
                <button class="btn btn-danger w-100 py-2" style="font-weight: bold;" @onclick="() => EndSessionRequested?.Invoke()">ZAKOŃCZ SESJĘ</button>
            </div>
        }
        <p class="mt-3 text-info text-center">@statusMessage</p>
    </div>
</div>

@code {
    private LiftIt.Presenters.WorkoutPresenter _presenter;
    private string statusMessage = "";

    // Słowniki wprowadzania danych tymczasowych (UI State) [cite: 33, 34]
    private HashSet<int> visibleExerciseSets = new();
    private Dictionary<int, int> perExerciseSetNumber = new();
    private Dictionary<int, decimal> perExerciseWeight = new();
    private Dictionary<int, int> perExerciseReps = new();

    [Parameter]
    public int PlanId { get; set; }

    public int CurrentTrainingId { get; set; } = 0;
    public string EndNotes { get; set; } = "";
    public List<LiftIt.Models.ExercisesInPlan> PlanLoadedItems { get; set; } = new();
    public Dictionary<int, List<LiftIt.Models.SetRecord>> ExerciseSets { get; set; } = new();

    public event Action StartSessionRequested;
    public event Action EndSessionRequested;
    public event Action<int, int, decimal, int> AddSetRequested;
    public event Action<int> LoadSetsRequested;

    protected override void OnInitialized()
    {
        _presenter = new LiftIt.Presenters.WorkoutPresenter(this, DbContext, StateService);
    }

    private void ToggleExerciseSets(int exerciseId)
    {
        if (visibleExerciseSets.Contains(exerciseId)) visibleExerciseSets.Remove(exerciseId);
        else
        {
            visibleExerciseSets.Add(exerciseId);
            if (!perExerciseSetNumber.ContainsKey(exerciseId)) perExerciseSetNumber[exerciseId] = 1;
            if (!perExerciseWeight.ContainsKey(exerciseId)) perExerciseWeight[exerciseId] = 0m;
            if (!perExerciseReps.ContainsKey(exerciseId)) perExerciseReps[exerciseId] = 8;
            if (!ExerciseSets.ContainsKey(exerciseId)) ExerciseSets[exerciseId] = new();

            LoadSetsRequested?.Invoke(exerciseId);
        }
    }

    private void TriggerAddSet(int exerciseId)
    {
        int setNum = perExerciseSetNumber.GetValueOrDefault(exerciseId, 1);
        decimal w = perExerciseWeight.GetValueOrDefault(exerciseId, 0m);
        int r = perExerciseReps.GetValueOrDefault(exerciseId, 8);

        AddSetRequested?.Invoke(exerciseId, setNum, w, r);
        perExerciseSetNumber[exerciseId]++; // Zwiększanie serii z UI po dodaniu [cite: 61]
    }

    public void ShowMessage(string msg)
    {
        statusMessage = msg;
        RefreshUI();
    }

    public void RefreshUI() => StateHasChanged();
}