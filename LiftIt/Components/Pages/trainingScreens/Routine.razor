@page "/routine"
@layout MainLayout
@implements LiftIt.Interfaces.IRoutineView
@inject LiftIt.Models.DatabaseContext DbContext
@inject LiftIt.Models.StateService StateService

<div class="tab-with-topbar-container">
    <div class="w-100 d-flex justify-content-between align-items-center header-container px-3 py-2">
        <NavLink href="trening" class="d-flex align-items-center text-decoration-none">
            <span class="bi bi-left-arrow accent-text"></span>
        </NavLink>
        <h3 class="m-0 page-title">Workout Routines</h3>
        <div style="width: 2rem;"></div>
    </div>

    <div class="p-3">
        <div class="card mb-4 p-3" style="background-color: var(--card-bg); border-radius: 12px; border: none;">
            <h4 class="mb-3" style="color: var(--text-main);">@(EditingPlanId == 0 ? "Utwórz nowy plan" : "Edytuj plan")</h4>

            <div class="mb-3">
                <label class="form-label text-muted">Nazwa rutyny</label>
                <input class="form-control" placeholder="e.g. Push Day" @bind="RoutineName" />
            </div>

            <h5 class="mt-3 text-muted">Wybierz ćwiczenia</h5>
            <div class="mb-3" style="max-height: 200px; overflow-y: auto; background-color: var(--input-bg); border-radius: 8px; padding: 10px;">
                @foreach (var e in AvailableExercises)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="ex_@e.Id" @bind="SelectedExercises[e.Id]" />
                        <label class="form-check-label text-main" for="ex_@e.Id">
                            <strong>@e.Name</strong> <span class="text-muted small">(@e.BodyPartName)</span>
                        </label>
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-secondary w-50" @onclick="() => CreateDraftRequested?.Invoke()">Utwórz roboczo</button>
                <button class="btn-primary-custom w-50 m-0" @onclick="() => SaveRoutineRequested?.Invoke()">
                    @(EditingPlanId == 0 ? "Zapisz" : "Zapisz zmiany")
                </button>
            </div>

            @if (LocalDrafts != null && LocalDrafts.Any())
            {
                <h6 class="mt-4 mb-2 text-muted">Twoje drafty</h6>
                @for (int i = 0; i < LocalDrafts.Count; i++)
                {
                    var draftIndex = i;
                    var d = LocalDrafts[i];
                    <div class="d-flex justify-content-between align-items-center p-2 mb-2" style="background-color: var(--options-bg); border-radius: 8px;">
                        <div>
                            <strong style="color: var(--accent-color);">@(string.IsNullOrEmpty(d.Name) ? "Brak nazwy" : d.Name)</strong>
                            <div class="small text-muted">@d.ExerciseIds.Count ćwiczeń</div>
                        </div>
                        <div>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => LoadDraftRequested?.Invoke(draftIndex)">Załaduj</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDraftRequested?.Invoke(draftIndex)">Usuń</button>
                        </div>
                    </div>
                }
            }

            <p class="text-info mt-3 mb-0 text-center">@statusMessage</p>
        </div>

        <h4 class="mb-3" style="color: var(--text-main);">Twoje plany</h4>
        @if (Plans.Count == 0)
        {
            <div class="text-center p-4" style="border: 1px dashed var(--input-border); border-radius: 8px;">
                <p class="text-muted m-0">Brak planów.</p>
            </div>
        }
        else
        {
            @foreach (var p in Plans)
            {
                <div class="card mb-2 p-3 d-flex flex-row justify-content-between align-items-center" style="background-color: var(--card-bg); border-radius: 8px; border: none;">
                    <div>
                        <h5 class="m-0" style="color: var(--text-main);">@p.Name</h5>
                        <small class="text-muted">Utworzono: @p.CreationDate.ToShortDateString()</small>
                    </div>
                    <div class="d-flex gap-1">
                        <a class="btn btn-sm btn-success fw-bold d-flex align-items-center" href="/workout/@p.Id">START</a>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditPlanRequested?.Invoke(p.Id)">Edytuj</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePlanRequested?.Invoke(p.Id)">Usuń</button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private LiftIt.Presenters.RoutinePresenter _presenter;
    private string statusMessage = "";

    public string RoutineName { get; set; } = "";
    public int EditingPlanId { get; set; } = 0;
    public Dictionary<int, bool> SelectedExercises { get; set; } = new();
    public List<LiftIt.Models.Exercise> AvailableExercises { get; set; } = new();
    public List<LiftIt.Models.WorkoutPlan> Plans { get; set; } = new();
    public List<LiftIt.Models.RoutineDraft> LocalDrafts { get; set; } = new();

    public event Action InitializeDataRequested;
    public event Action CreateDraftRequested;
    public event Action<int> LoadDraftRequested;
    public event Action<int> DeleteDraftRequested;
    public event Action SaveRoutineRequested;
    public event Action<int> EditPlanRequested;
    public event Action<int> DeletePlanRequested;

    protected override void OnInitialized()
    {
        _presenter = new LiftIt.Presenters.RoutinePresenter(this, DbContext, StateService);
        InitializeDataRequested?.Invoke();
    }

    public void ShowMessage(string message)
    {
        statusMessage = message;
        RefreshUI();
    }

    public void RefreshUI() => StateHasChanged();
}