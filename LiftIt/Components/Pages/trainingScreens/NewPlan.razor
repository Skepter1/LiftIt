@page "/NewPlan"
@page "/NewPlan/{PlanId:int}"  
@layout MainLayout
@implements LiftIt.Interfaces.INewPlanView
@inject LiftIt.Models.DatabaseContext DbContext
@inject LiftIt.Models.StateService StateService

<div class="tab-with-topbar-container">

    <div class="w-100 d-flex justify-content-between align-items-center header-container px-3 py-2">
        <NavLink href="trening" class="d-flex align-items-center text-decoration-none">
            <span class="bi bi-left-arrow accent-text"></span>
        </NavLink>
        <h3 class="m-0 page-title">Twój plan treningowy</h3>
        <div style="width: 2rem;"></div>
    </div>

    <div class="p-3">

        <div class="card" style="color: var(--text-darker);">
            <label class="form-label main-text small fw-bold uppercase mb-2" style="letter-spacing: 0.5px;">Wybierz część ciała</label>
            <select class="form-control" @onchange="OnBodyPartSelectChanged">
                <option value="">-- wybierz część ciała --</option>
                @foreach (var bp in BodyPartsList)
                {
                    <option value="@bp.Id">@bp.Name</option>
                }
            </select>
        </div>

        @if (Exercises != null && Exercises.Any())
        {
            <h4>Dostępne ćwiczenia</h4>
            <div class="scrollable-exercise-list mb-4" style="max-height: 220px; overflow-y: auto;">
                @foreach (var ex in Exercises)
                {
                    <div class="exercise-row-item">
                        <span class="exercise-name-text">@ex.Name</span>
                        <button class="btn btn-sm btn-success" @onclick="() => AddToPlanRequested?.Invoke(ex)">Dodaj</button>
                    </div>
                }
            </div>
        }

        @if (TrainingPlan != null && TrainingPlan.Count > 0)
        {
            <h4>Mój plan</h4>
            <div class="scrollable-exercise-list mb-4">
                @foreach (var ex in TrainingPlan)
                {
                    <div class="exercise-row-item">
                        <span class="exercise-name-text" style="color: var(--accent-color);">@ex.Name</span>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveUpRequested?.Invoke(ex)">
                                <span class="fw-bold">↑</span>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveDownRequested?.Invoke(ex)">
                                <span class="fw-bold">↓</span>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveFromPlanRequested?.Invoke(ex)">❌</button>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="card">
            <label class="main-text small fw-bold uppercase mb-2" style="letter-spacing: 0.5px;">Nazwa planu</label>
            <input class="form-control mb-3" @bind="PlanName" placeholder="np. Trening A - Klatka i Biceps" style="background-color: var(--input-bg); color: var(--text-main);" />

            <button class="btn-primary-custom w-100 m-0" @onclick="() => SavePlanRequested?.Invoke()">
                💾 Zapisz plan
            </button>
        </div>

        <p class="text-info text-center mt-3 fw-bold">@feedbackMessage</p>
    </div>
</div>

@code {
    private LiftIt.Presenters.NewPlanPresenter _presenter;
    private string feedbackMessage = "";

    [Parameter]
    public int PlanId { get; set; }
    public string PlanName { get; set; } = "";
    public List<LiftIt.Models.BodyPart> BodyPartsList { get; set; } = new();
    public List<LiftIt.Models.Exercise> Exercises { get; set; } = new();
    public List<LiftIt.Models.Exercise> TrainingPlan { get; set; } = new();

    public event Action InitializeRequested;
    public event Action<int> BodyPartChanged;
    public event Action<LiftIt.Models.Exercise> AddToPlanRequested;
    public event Action<LiftIt.Models.Exercise> RemoveFromPlanRequested;
    public event Action<LiftIt.Models.Exercise> MoveUpRequested;
    public event Action<LiftIt.Models.Exercise> MoveDownRequested;
    public event Action SavePlanRequested;

    protected override void OnInitialized()
    {
        _presenter = new LiftIt.Presenters.NewPlanPresenter(this, DbContext, StateService);
        InitializeRequested?.Invoke();
    }

    private void OnBodyPartSelectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id)) BodyPartChanged?.Invoke(id);
        else BodyPartChanged?.Invoke(0);
    }

    public void ShowMessage(string message)
    {
        feedbackMessage = message;
        RefreshUI();
    }

    public void RefreshUI() => StateHasChanged();
}