@page "/aboutandsupport"
@layout MainLayout

<div class="tab-with-topbar-container">

    <div class="w-100 d-flex justify-content-between align-items-center header-container px-3 py-2">
        <NavLink href="logowanie" class="d-flex align-items-center">
            <span class="bi bi-left-arrow accent-text"></span>
        </NavLink>
        <h3 class="m-0 page-title">About & Support</h3>
        <div style="width: 2rem;"></div>
    </div>

    <div class="blank-screen-container">
        <div class="support-wrapper">

            <div class="support-card info-card text-center mb-4">
                <div class="app-logo-placeholder">
                    <span class="bi-menu-icon bi-graph-up-fill-nav-menu logo-icon"></span>
                </div>
                <h4 class="app-name mt-2">LiftIt</h4>
                <p class="app-version">Version 1.0.0 (Beta)</p>
                <p class="app-description">
                    Modern workout tracker designed for strength athletes. Plan, track, and analyze your gym progress without paper notes.
                </p>
                <div class="authors-box mt-3">
                    <span class="authors-title">Created by:</span>
                    <p class="authors-names m-0 fw-bolder">Michał Ciszewski (boss)</p>
                    <p class="authors-names m-0">Daniel Głąbik</p>
                    <p class="authors-names m-0">Bartosz Orlef</p>
                    <p class="authors-names m-0">Piotr Zdebik</p>
                </div>
            </div>

            <h5 class="section-heading mb-3">How can we help?</h5>

            <div class="support-card action-card mb-3">
                <div class="action-card-content">
                    <span class="bi-menu-icon bi-house-door-fill-nav-menu action-icon"></span>
                    <div class="action-text">
                        <h6>Frequently Asked Questions</h6>
                        <p>Quick answers to common problems</p>
                    </div>
                </div>
                <span class="bi-chevron-right"></span>
            </div>

            <div class="support-card action-card mb-3">
                <div class="action-card-content">
                    <span class="bi-menu-icon bi-person-fill-nav-menu action-icon"></span>
                    <div class="action-text">
                        <h6>Contact Support</h6>
                        <p>Send an email to our tech team</p>
                    </div>
                </div>
                <span class="bi-chevron-right"></span>
            </div>

            <div class="text-center mt-5 copyright-text">
                <p>© 2026 LiftIt Project. All rights reserved.</p>
            </div>

        </div>
    </div>
</div>
