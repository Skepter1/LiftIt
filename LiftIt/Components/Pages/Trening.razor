@page "/trening"
@layout MainLayout
@inject LiftIt.Models.StateService State

<div class="auth-container">
    @if (!State.IsLoggedIn)
    {
        <div class="auth-card">
            <h1>
                Welcome to
                <span class="accent-text">LiftIt</span>
            </h1>
            <p>Please <a class="accent-text text-decoration-none" href="logowanie">Sign In</a> to continue.</p>
        </div>
    } else
    {
        <div class="w-100 d-flex justify-content-center header-container">
            <h3>Workout</h3>
        </div>
        <div class="card">
            <NavLink class="d-flex flex-row align-items-center justify-content-center nav-link " href="" Match="NavLinkMatch.All">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-square-fill mx-2" viewBox="0 0 16 16">
                    <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm6.5 4.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3a.5.5 0 0 1 1 0" />
                </svg>
                <span class="nav-text">Start your workout</span>
            </NavLink>
        </div>
    }
</div>



