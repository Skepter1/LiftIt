@page "/trening"
@layout MainLayout
@implements LiftIt.Interfaces.ITreningView
@inject LiftIt.Models.StateService State
@inject NavigationManager Navigation

<div class="workout-dashboard-container">
    @if (!State.IsLoggedIn)
    {
        <div class="auth-card m-auto">
            <h1>Welcome to <span class="accent-text">LiftIt</span></h1>
            <p class="mt-3">Please <a class="accent-text text-decoration-none fw-bold" href="logowanie">Sign In</a> to continue.</p>
        </div>
    }
    else
    {
        <div class="w-100 d-flex justify-content-center align-items-center header-container px-3 py-2">
            <h3 class="m-0 page-title accent-text">Workout</h3>
        </div>
        <div class="dashboard-wrapper">

            <div class="dashboard-header mb-4">
                <h2 class="m-0">Start Workout</h2>
                <p class="text-muted m-0">Choose how you want to train today</p>
            </div>

            <NavLink class="dashboard-action-tile quick-start text-decoration-none" href="workout">
                <div class="tile-content">
                    <div class="tile-icon-box">
                        <span class="bi-menu-icon bi-graph-up-fill-nav-menu tile-icon"></span>
                    </div>
                    <div class="tile-text">
                        <h3>Start an Empty Workout</h3>
                        <p>Track exercises, sets, and weight in real-time</p>
                    </div>
                </div>
                <span class="bi-chevron-right text-muted"></span>
            </NavLink>

            <div class="section-divider my-4">
                <h5>Routines</h5>
            </div>

            <NavLink class="dashboard-action-tile create-routine text-decoration-none" href="routine">
                <div class="tile-content">
                    <div class="tile-icon-box alternate">
                        <span class="bi-menu-icon bi-person-fill-nav-menu tile-icon"></span>
                    </div>
                    <div class="tile-text">
                        <h3>Create New Routine</h3>
                        <p>Save a reusable template for your upcoming workouts</p>
                    </div>
                </div>
                <span class="bi-chevron-right text-muted"></span>
            </NavLink>

            <div class="empty-routines-placeholder text-center mt-4 p-4">
                <p class="m-0 text-muted">Your custom workout templates will appear here.</p>
            </div>

        </div>
    }
</div>

@* @code {
    [Inject] public Models.DatabaseContext DbContext { get; set; } // Wstrzykujemy model bazy danych
    [Inject] public Models.StateService StateService { get; set; }

    // View / presenter
    private LiftIt.Presenters.TreningPresenter presenter;
    private List<LiftIt.Models.Exercise> exercises;
    private Dictionary<int, bool> selected = new();
    public string RoutineName { get; set; } = "";
    public List<int> SelectedExerciseIds => selected.Where(kv => kv.Value).Select(kv => kv.Key).ToList();
    public event Action CreateRoutineRequested;
    public event Action SaveRoutineRequested;

    // plans
    private List<LiftIt.Models.WorkoutPlan> plans;
    private int editingPlanId = 0;

    // live session
    private int currentTrainingId = 0;
    private List<LiftIt.Models.SetRecord> sets = new();
    private string endNotes = "";

    // plan -> live
    private List<LiftIt.Models.ExercisesInPlan> planLoadedItems = null;

    // per-exercise sets UI
    private Dictionary<int, List<LiftIt.Models.SetRecord>> exerciseSets = new();
    private HashSet<int> visibleExerciseSets = new();
    private Dictionary<int, int> perExerciseSetNumber = new();
    private Dictionary<int, decimal> perExerciseWeight = new();
    private Dictionary<int, int> perExerciseReps = new();

    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        presenter = new LiftIt.Presenters.TreningPresenter(this, DbContext, StateService);
        exercises = await DbContext.GetAllExercisesAsync();
        foreach (var e in exercises) selected[e.Id] = false;
        plans = await presenter.LoadUserPlansAsync();
    }

    // Plans: load/create/edit/delete
    async Task LoadPlans()
    {
        plans = await presenter.LoadUserPlansAsync();
        StateHasChanged();
    }

    private record RoutineDraftItem(int Id, string Name, List<int> ExerciseIds, DateTime CreatedAt);

    private List<RoutineDraftItem> localDrafts = new();
    private int nextDraftId = 1;

    void CreateRoutine()
    {
        // Zbierz aktualny draft z UI
        var draft = new RoutineDraftItem(
            nextDraftId++,
            RoutineName ?? string.Empty,
            SelectedExerciseIds.ToList(),
            DateTime.Now
        );

        // Zapisz lokalnie (w pamięci komponentu)
        localDrafts.Insert(0, draft);

        // Wyczyść UI (jak wcześniej)
        editingPlanId = 0;
        RoutineName = "";
        foreach (var k in selected.Keys.ToList()) selected[k] = false;

        message = $"Draft utworzony lokalnie (id={draft.Id}).";
    }

    void LoadDraft(int draftId)
    {
        var d = localDrafts.FirstOrDefault(x => x.Id == draftId);
        if (d == null) return;

        // załaduj do formularza
        editingPlanId = 0;
        RoutineName = d.Name;
        foreach (var k in selected.Keys.ToList()) selected[k] = d.ExerciseIds.Contains(k);
        message = $"Załadowano draft {d.Id}.";
    }

    void DeleteDraft(int draftId)
    {
        localDrafts.RemoveAll(x => x.Id == draftId);
        message = $"Usunięto draft {draftId}.";
    }

    async Task SaveRoutine()
    {
        if (editingPlanId == 0)
        {
            SaveRoutineRequested?.Invoke();
            await Task.Delay(200);
            await LoadPlans();
        }
        else
        {
            var ok = await presenter.UpdatePlanNameAsync(editingPlanId, RoutineName);
            await presenter.UpdatePlanExercisesAsync(editingPlanId, SelectedExerciseIds);
            message = ok ? "Zapisano zmiany w planie." : "Błąd zapisu nazwy planu.";
            await LoadPlans();
        }
    }

    async Task EditPlan(int planId)
    {
        editingPlanId = planId;
        var details = await presenter.GetPlanDetailsAsync(planId);
        if (details.plan != null)
        {
            RoutineName = details.plan.Name;
            var ids = details.items.Select(x => x.ExerciseId).ToHashSet();
            foreach (var k in selected.Keys.ToList()) selected[k] = ids.Contains(k);
            message = $"Edytujesz plan: {RoutineName}";
        }
    }

    async Task DeletePlan(int planId)
    {
        var ok = await presenter.DeletePlanAsync(planId);
        message = ok ? "Usunięto plan." : "Nie udało się usunąć planu.";
        await LoadPlans();
    }

    // Live session: start/add set/end
    async Task StartSession()
    {
        currentTrainingId = await presenter.StartSessionAsync();
        sets = new List<LiftIt.Models.SetRecord>();
        planLoadedItems = null;
        message = currentTrainingId > 0 ? "Sesja rozpoczęta." : "Zaloguj się aby uruchomić sesję.";
    }

    async Task AddSetToExercise(int exerciseId)
    {
        if (currentTrainingId == 0) { message = "Najpierw uruchom sesję."; return; }

        // Bezpieczne odczytanie wartości ze słowników z wartościami domyślnymi
        int setNum = perExerciseSetNumber.ContainsKey(exerciseId) ? perExerciseSetNumber[exerciseId] : 1;
        decimal w = perExerciseWeight.ContainsKey(exerciseId) ? perExerciseWeight[exerciseId] : 0m;
        int r = perExerciseReps.ContainsKey(exerciseId) ? perExerciseReps[exerciseId] : 8;

        try
        {
            var id = await presenter.AddSetAsync(currentTrainingId, exerciseId, setNum, w, r);
            if (id > 0)
            {
                await LoadSetsForExercise(exerciseId);
                message = "Dodano serię.";
            }
            else message = "Błąd dodawania.";
        }
        catch (Exception ex)
        {
            message = "Błąd: " + ex.Message;
        }
    }

    async Task LoadSetsForExercise(int exerciseId)
    {
        if (currentTrainingId == 0) return;
        var all = await presenter.GetSetsForSessionAsync(currentTrainingId);
        var filtered = all.Where(s => s.ExerciseId == exerciseId).OrderBy(s => s.SetNumber).ToList();
        exerciseSets[exerciseId] = filtered;
        StateHasChanged();
    }

    void ToggleExerciseSets(int exerciseId)
    {
        if (visibleExerciseSets.Contains(exerciseId))
        {
            visibleExerciseSets.Remove(exerciseId);
        }
        else
        {
            visibleExerciseSets.Add(exerciseId);

            // Upewniamy się, że klucze istnieją zanim będą użyte w @bind
            if (!perExerciseSetNumber.ContainsKey(exerciseId)) perExerciseSetNumber[exerciseId] = 1;
            if (!perExerciseWeight.ContainsKey(exerciseId)) perExerciseWeight[exerciseId] = 0m;
            if (!perExerciseReps.ContainsKey(exerciseId)) perExerciseReps[exerciseId] = 8;

            if (!exerciseSets.ContainsKey(exerciseId)) exerciseSets[exerciseId] = new List<LiftIt.Models.SetRecord>();

            // Załaduj istniejące serie (asynchronicznie)
            _ = LoadSetsForExercise(exerciseId);
        }
    }

    async Task EndSession()
    {
        if (currentTrainingId == 0) { message = "Brak aktywnej sesji."; return; }
        var ok = await presenter.EndSessionAsync(currentTrainingId, endNotes);
        if (ok)
        {
            message = "Sesja zakończona.";
            currentTrainingId = 0;
            sets = new List<LiftIt.Models.SetRecord>();
            planLoadedItems = null;
            endNotes = "";
            visibleExerciseSets.Clear();
            exerciseSets.Clear();
        }
        else message = "Błąd zakończenia sesji.";
    }

    async Task StartPlan(int planId)
    {
        var res = await presenter.RunPlanAsSessionAsync(planId);
        currentTrainingId = res.trainingId;
        planLoadedItems = res.planItems;
        sets = new List<LiftIt.Models.SetRecord>();
        visibleExerciseSets.Clear();
        exerciseSets.Clear();
        message = currentTrainingId > 0 ? "Uruchomiono plan jako sesję." : "Błąd uruchomienia planu.";
    }

    // ITreningView implementation
    public void ShowMessage(string message)
    {
        this.message = message;
        StateHasChanged();
    }
} *@