@page "/"
@implements IHomeView
@inject HomePresenter Presenter
@inject LiftIt.Models.StateService State

<div class="auth-container">
    @if (!State.IsLoggedIn)
    {
        <div class="auth-card m-auto">
            <h1>Welcome to <span class="accent-text">LiftIt</span></h1>
            <p class="mt-3">Please <a class="accent-text text-decoration-none fw-bold" href="logowanie">Sign In</a> to continue.</p>
        </div>
    } else {
        <div class="home-container">
        <div class="main-header">
                <h3>Your Training History</h3>
                <p style="color: var(--text-darker)">View your progress</p>
        </div>

        @if (Trainings == null)
        {
                <p class="status-text">Loading workouts...</p>
        }
        else if (!Trainings.Any())
        {
                <p class="status-text">No workouts in your exercise history. Time to lift some weights!</p>
        }
        else
        {
            <div class="training-list">
                @foreach (var training in Trainings)
                {
                    <div class="training-card">
                        <div class="card-top">
                            <h4>Training #@training.Id</h4>
                            <p class="date">@training.TrainingDate.ToString("dd.MM.yyyy")</p>
                        </div>

                        @foreach (var exercise in training.Exercises)
                        {
                            <div class="exercise-group">
                                <h5>💪 @exercise.ExerciseName</h5>
                                <ul class="sets-list">
                                    @foreach (var set in exercise.Sets)
                                    {
                                        <li class="set-item">
                                            <span>Set @set.SetNumber</span>
                                            <span><strong>@set.Weight.ToString("0.##")</strong> kg x <strong>@set.Reps</strong> reps.</span>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
    }
</div>

@code {
    public List<TrainingHistoryDto> Trainings { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await Presenter.InitAsync(this);
    }
}